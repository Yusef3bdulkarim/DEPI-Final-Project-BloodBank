<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:padding="24dp"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/ip"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/google_logo"/>
    <ImageView
        android:alpha=".7"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/android_logo"
        />
    <TextView
        android:id="@+id/ic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/ip"
        android:text="Google is a multinational technology company founded in 1998 by Larry Page and Sergey Brin while they were PhD students at Stanford University.

It started as a search engine designed to organize the world’s information and make it universally accessible and useful. Today, Google offers a wide range of products and services
    "
android:textSize="22sp" />

    <TextView
        android:id="@+id/im"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="mountain view,california"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/ic"
        android:drawableStart="@drawable/baseline_add_location_24" />





</androidx.constraintlayout.widget.ConstraintLayout>